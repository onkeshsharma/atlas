{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-e2e/types/**/*.ts",
    ".next-e2e/dev/types/**/*.ts",
    ".next-e2e-m9/types/**/*.ts",
    ".next-e2e-m9/dev/types/**/*.ts",
    ".next-e2e-m14/types/**/*.ts",
    ".next-e2e-m14/dev/types/**/*.ts",
    ".next-e2e-m10/types/**/*.ts",
    ".next-e2e-m10/dev/types/**/*.ts",
    ".next-e2e-debug/types/**/*.ts",
    ".next-e2e-debug/dev/types/**/*.ts",
    ".next-e2e-m11/types/**/*.ts",
    ".next-e2e-m11/dev/types/**/*.ts",
    ".next-e2e-m12/types/**/*.ts",
    ".next-e2e-m12/dev/types/**/*.ts",
    ".next-e2e-m13/types/**/*.ts",
    ".next-e2e-m13/dev/types/**/*.ts",
    ".next-e2e-m15/types/**/*.ts",
    ".next-e2e-m15/dev/types/**/*.ts",
    ".next-e2e-m16/types/**/*.ts",
    ".next-e2e-m16/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages"
  ]
}
