# Atlas v2 — every env var the app reads, documented (M5 charter §1).
# Copy to .env.local and fill in. Never commit .env.local.

# ── Neon Postgres (project: atlas-v2, id calm-union-34473575, branch main) ──
# Connection string: Neon console → atlas-v2 → main → Connect, or
#   npx neonctl connection-string main --project-id calm-union-34473575
DATABASE_URL=postgresql://<role>:<password>@<endpoint>.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# ── Neon Auth (Better Auth hosted by Neon; enabled on branch main) ──
# Base URL: Neon console → atlas-v2 → main → Auth → Configuration, or
#   GET https://console.neon.tech/api/v2/projects/{project}/branches/{branch}/auth
NEON_AUTH_BASE_URL=https://<endpoint>.neonauth.ap-southeast-2.aws.neon.tech/neondb/auth

# 32+ char secret signing the session-cache cookie. Generate:
#   openssl rand -base64 32   (PowerShell:
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32)))
NEON_AUTH_COOKIE_SECRET=<32-byte base64 secret>

# ── Atlas bootstrap ──
# The Owner code: sign-up creates THE Owner account only when this code is
# presented (exactly one Owner per instance — PRD). Collaborators never use
# it; they join via invite magic links.
ATLAS_OWNER_CODE=ATLAS-OWNER-<random>

# Absolute origin used when composing invite magic links (no trailing slash).
ATLAS_APP_URL=http://localhost:3000
